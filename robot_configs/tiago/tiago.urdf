<?xml version="1.0" ?>
<!-- PAL Robotics TIAGo URDF - 7-DOF arm, no meshes -->
<!-- Joint axes: Z, Y, Z, Y, Z, Y, Z -->
<!-- DH approx: d=[0.15, 0, 0.32, 0, 0.32, 0, 0.15], a=[0, 0, 0, 0, 0, 0, 0] -->
<robot name="tiago">
  <link name="base_link">
    <inertial>
      <mass value="28.0"/>
      <inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.5" iyz="0.0" izz="0.3"/>
    </inertial>
  </link>

  <joint name="torso_lift_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="torso_lift_link"/>
    <origin xyz="-0.062 0 0.828" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.35" effort="2000.0" velocity="0.07"/>
  </joint>

  <link name="torso_lift_link">
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.05"/>
    </inertial>
  </link>

  <joint name="arm_1_joint" type="revolute">
    <parent link="torso_lift_link"/>
    <child link="arm_1_link"/>
    <origin xyz="0.157 0.019 0.15" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.1781" upper="1.5708" effort="43.0" velocity="2.7"/>
  </joint>

  <link name="arm_1_link">
    <inertial>
      <mass value="1.8"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="arm_2_joint" type="revolute">
    <parent link="arm_1_link"/>
    <child link="arm_2_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.1781" upper="1.5708" effort="43.0" velocity="2.7"/>
  </joint>

  <link name="arm_2_link">
    <inertial>
      <mass value="1.8"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="arm_3_joint" type="revolute">
    <parent link="arm_2_link"/>
    <child link="arm_3_link"/>
    <origin xyz="0 0 0.32" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.5779" upper="0.5585" effort="26.0" velocity="4.8"/>
  </joint>

  <link name="arm_3_link">
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="arm_4_joint" type="revolute">
    <parent link="arm_3_link"/>
    <child link="arm_4_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.3927" upper="2.3562" effort="26.0" velocity="4.8"/>
  </joint>

  <link name="arm_4_link">
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="arm_5_joint" type="revolute">
    <parent link="arm_4_link"/>
    <child link="arm_5_link"/>
    <origin xyz="0 0 0.32" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0944" upper="2.0944" effort="3.0" velocity="4.8"/>
  </joint>

  <link name="arm_5_link">
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="arm_6_joint" type="revolute">
    <parent link="arm_5_link"/>
    <child link="arm_6_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.4137" upper="1.4137" effort="3.0" velocity="4.8"/>
  </joint>

  <link name="arm_6_link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="arm_7_joint" type="revolute">
    <parent link="arm_6_link"/>
    <child link="arm_7_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0944" upper="2.0944" effort="3.0" velocity="4.8"/>
  </joint>

  <link name="arm_7_link">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="arm_tool_joint" type="fixed">
    <parent link="arm_7_link"/>
    <child link="arm_tool_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="arm_tool_link">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
