<?xml version="1.0" ?>
<!-- Rethink Robotics Baxter Right Arm URDF - 7-DOF, no meshes -->
<!-- Joint axes: Z, Y, X, Y, X, Y, X -->
<!-- DH: d=[0.2703, 0, 0, 0.3644, 0, 0.3743, 0], a=[0.069, 0, 0.069, 0, 0.010, 0, 0] -->
<!-- Right arm (mirrored Y from left) -->
<robot name="baxter_right">
  <link name="base_link">
    <inertial>
      <mass value="35.0"/>
      <inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.5" iyz="0.0" izz="0.3"/>
    </inertial>
  </link>

  <joint name="right_s0" type="revolute">
    <parent link="base_link"/>
    <child link="right_upper_shoulder"/>
    <origin xyz="0.064 -0.259 0.2703" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.7016" upper="1.7016" effort="50.0" velocity="2.0"/>
  </joint>

  <link name="right_upper_shoulder">
    <inertial>
      <mass value="5.7"/>
      <inertia ixx="0.05" ixy="0.0" ixz="0.0" iyy="0.05" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="right_s1" type="revolute">
    <parent link="right_upper_shoulder"/>
    <child link="right_lower_shoulder"/>
    <origin xyz="0.069 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.1470" upper="1.0470" effort="50.0" velocity="2.0"/>
  </joint>

  <link name="right_lower_shoulder">
    <inertial>
      <mass value="3.2"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="right_e0" type="revolute">
    <parent link="right_lower_shoulder"/>
    <child link="right_upper_elbow"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.0541" upper="3.0541" effort="50.0" velocity="2.0"/>
  </joint>

  <link name="right_upper_elbow">
    <inertial>
      <mass value="4.3"/>
      <inertia ixx="0.03" ixy="0.0" ixz="0.0" iyy="0.03" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="right_e1" type="revolute">
    <parent link="right_upper_elbow"/>
    <child link="right_lower_elbow"/>
    <origin xyz="0.069 0 0.3644" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.0500" upper="2.6180" effort="50.0" velocity="2.0"/>
  </joint>

  <link name="right_lower_elbow">
    <inertial>
      <mass value="2.1"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="right_w0" type="revolute">
    <parent link="right_lower_elbow"/>
    <child link="right_upper_forearm"/>
    <origin xyz="0.010 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.0590" upper="3.0590" effort="15.0" velocity="4.0"/>
  </joint>

  <link name="right_upper_forearm">
    <inertial>
      <mass value="2.2"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="right_w1" type="revolute">
    <parent link="right_upper_forearm"/>
    <child link="right_lower_forearm"/>
    <origin xyz="0 0 0.3743" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0940" upper="2.0940" effort="15.0" velocity="4.0"/>
  </joint>

  <link name="right_lower_forearm">
    <inertial>
      <mass value="1.4"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="right_w2" type="revolute">
    <parent link="right_lower_forearm"/>
    <child link="right_hand"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.0590" upper="3.0590" effort="15.0" velocity="4.0"/>
  </joint>

  <link name="right_hand">
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="right_gripper_fixed" type="fixed">
    <parent link="right_hand"/>
    <child link="right_gripper_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <link name="right_gripper_link">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
