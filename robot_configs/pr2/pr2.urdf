<?xml version="1.0" ?>
<!-- Willow Garage PR2 URDF - right arm 7-DOF, no meshes -->
<!-- Joint axes: Z, Y, X, Y, X, Y, X -->
<!-- DH: d=[0.4, 0, 0, 0, 0, 0, 0], a=[0.1, 0.4, 0, 0.321, 0, 0, 0] -->
<robot name="pr2">
  <link name="base_link">
    <inertial>
      <mass value="50.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="0.8"/>
    </inertial>
  </link>

  <joint name="torso_lift_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="torso_lift_link"/>
    <origin xyz="-0.05 0 0.739675" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.33" effort="10000.0" velocity="0.013"/>
  </joint>

  <link name="torso_lift_link">
    <inertial>
      <mass value="36.0"/>
      <inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.5" iyz="0.0" izz="0.3"/>
    </inertial>
  </link>

  <joint name="r_shoulder_pan_joint" type="revolute">
    <parent link="torso_lift_link"/>
    <child link="r_shoulder_pan_link"/>
    <origin xyz="0 -0.188 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.2854" upper="0.7146" effort="30.0" velocity="2.088"/>
  </joint>

  <link name="r_shoulder_pan_link">
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="r_shoulder_lift_joint" type="revolute">
    <parent link="r_shoulder_pan_link"/>
    <child link="r_shoulder_lift_link"/>
    <origin xyz="0.1 0 0.4" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5236" upper="1.3963" effort="30.0" velocity="2.082"/>
  </joint>

  <link name="r_shoulder_lift_link">
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="r_upper_arm_roll_joint" type="revolute">
    <parent link="r_shoulder_lift_link"/>
    <child link="r_upper_arm_roll_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.9000" upper="0.8000" effort="30.0" velocity="3.27"/>
  </joint>

  <link name="r_upper_arm_roll_link">
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="r_elbow_flex_joint" type="revolute">
    <parent link="r_upper_arm_roll_link"/>
    <child link="r_elbow_flex_link"/>
    <origin xyz="0.4 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.3213" upper="0.0" effort="30.0" velocity="3.30"/>
  </joint>

  <link name="r_elbow_flex_link">
    <inertial>
      <mass value="1.9"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="r_forearm_roll_joint" type="continuous">
    <parent link="r_elbow_flex_link"/>
    <child link="r_forearm_roll_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="30.0" velocity="3.60"/>
  </joint>

  <link name="r_forearm_roll_link">
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="r_wrist_flex_joint" type="revolute">
    <parent link="r_forearm_roll_link"/>
    <child link="r_wrist_flex_link"/>
    <origin xyz="0.321 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="0.0" effort="10.0" velocity="3.078"/>
  </joint>

  <link name="r_wrist_flex_link">
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="r_wrist_roll_joint" type="continuous">
    <parent link="r_wrist_flex_link"/>
    <child link="r_wrist_roll_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="10.0" velocity="3.60"/>
  </joint>

  <link name="r_wrist_roll_link">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="r_gripper_fixed_joint" type="fixed">
    <parent link="r_wrist_roll_link"/>
    <child link="r_gripper_link"/>
    <origin xyz="0.18 0 0" rpy="0 0 0"/>
  </joint>

  <link name="r_gripper_link">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
</robot>
