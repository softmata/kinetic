<?xml version="1.0"?>
<!-- Simplified xArm6 URDF - correct kinematics, no meshes -->
<robot name="xarm6">
  <link name="link_base">
    <inertial>
      <mass value="2.7"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.07" length="0.10"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="link_base"/>
    <child link="link1"/>
    <origin xyz="0 0 0.267" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="50" velocity="3.1416"/>
  </joint>

  <link name="link1">
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.08"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.059" upper="2.059" effort="50" velocity="3.1416"/>
  </joint>

  <link name="link2">
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.01"/>
    </inertial>
    <collision>
      <origin xyz="0 -0.1466 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.28"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 -0.2932 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2832" upper="6.2832" effort="50" velocity="3.1416"/>
  </joint>

  <link name="link3">
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.015" ixy="0.0" ixz="0.0" iyy="0.015" iyz="0.0" izz="0.008"/>
    </inertial>
    <collision>
      <origin xyz="0.026 -0.179 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.34"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.0525 -0.3581 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.192" upper="3.927" effort="20" velocity="3.1416"/>
  </joint>

  <link name="link4">
    <inertial>
      <mass value="1.3"/>
      <inertia ixx="0.008" ixy="0.0" ixz="0.0" iyy="0.008" iyz="0.0" izz="0.004"/>
    </inertial>
    <collision>
      <origin xyz="0.0388 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.07"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0.0775 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="20" velocity="3.1416"/>
  </joint>

  <link name="link5">
    <inertial>
      <mass value="1.3"/>
      <inertia ixx="0.008" ixy="0.0" ixz="0.0" iyy="0.008" iyz="0.0" izz="0.004"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.692" upper="3.142" effort="20" velocity="3.1416"/>
  </joint>

  <link name="link6">
