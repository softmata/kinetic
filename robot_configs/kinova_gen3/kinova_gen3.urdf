<?xml version="1.0"?>
<!-- Simplified Kinova Gen3 URDF - correct kinematics, no meshes -->
<!-- Joint axes: all Z-axis with frame rotations between links (7-DOF) -->
<!-- Real Gen3 has actuator position limits on all joints -->
<robot name="kinova_gen3">
  <link name="base_link">
    <inertial>
      <mass value="1.4"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.1564" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="39" velocity="1.39"/>
  </joint>

  <link name="shoulder_link">
    <inertial>
      <mass value="1.3"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="shoulder_link"/>
    <child link="half_arm_1_link"/>
    <origin xyz="0.0054 0 0.1284" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.41" upper="2.41" effort="39" velocity="1.39"/>
  </joint>

  <link name="half_arm_1_link">
    <inertial>
      <mass value="1.1"/>
      <inertia ixx="0.008" ixy="0.0" ixz="0.0" iyy="0.008" iyz="0.0" izz="0.004"/>
    </inertial>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="half_arm_1_link"/>
    <child link="half_arm_2_link"/>
    <origin xyz="-0.0064 0 0.2104" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="39" velocity="1.39"/>
  </joint>

  <link name="half_arm_2_link">
    <inertial>
      <mass value="1.1"/>
      <inertia ixx="0.008" ixy="0.0" ixz="0.0" iyy="0.008" iyz="0.0" izz="0.004"/>
    </inertial>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="half_arm_2_link"/>
    <child link="forearm_link"/>
    <origin xyz="-0.0064 0 0.2104" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.66" upper="2.66" effort="39" velocity="1.39"/>
  </joint>

  <link name="forearm_link">
    <inertial>
      <mass value="0.9"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="forearm_link"/>
    <child link="spherical_wrist_1_link"/>
    <origin xyz="-0.0064 0 0.2084" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="9" velocity="1.22"/>
  </joint>

  <link name="spherical_wrist_1_link">
    <inertial>
      <mass value="0.7"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="joint_6" type="revolute">
    <parent link="spherical_wrist_1_link"/>
    <child link="spherical_wrist_2_link"/>
    <origin xyz="0 0 0.1059" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.23" upper="2.23" effort="9" velocity="1.22"/>
  </joint>

  <link name="spherical_wrist_2_link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_7" type="revolute">
    <parent link="spherical_wrist_2_link"/>
    <child link="bracelet_link"/>
    <origin xyz="0 0 0.1059" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="9" velocity="1.22"/>
  </joint>

  <link name="bracelet_link">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="ee_fixed_joint" type="fixed">
    <parent link="bracelet_link"/>
    <child link="end_effector_link"/>
    <origin xyz="0 0 0.0615" rpy="0 0 -2.7053"/>
  </joint>

  <link name="end_effector_link">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
