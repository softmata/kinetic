<?xml version="1.0" ?>
<!-- Staubli TX2-60 URDF - high-speed industrial robot, no meshes -->
<!-- Joint axes: Z, Y, Y, Y, Z, Y (standard 6-DOF convention) -->
<!-- DH: d=[0.375, 0, 0, 0.295, 0, 0.070], a=[0, 0.290, 0.020, 0, 0, 0] -->
<robot name="staubli_tx260">
  <link name="base_link">
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.03" ixy="0.0" ixz="0.0" iyy="0.03" iyz="0.0" izz="0.03"/>
    </inertial>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.375" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="80.0" velocity="8.90"/>
  </joint>

  <link name="link_1">
    <inertial>
      <mass value="4.5"/>
      <inertia ixx="0.03" ixy="0.0" ixz="0.0" iyy="0.03" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.2253" upper="2.2253" effort="80.0" velocity="8.90"/>
  </joint>

  <link name="link_2">
    <inertial>
      <mass value="4.0"/>
      <inertia ixx="0.03" ixy="0.0" ixz="0.0" iyy="0.03" iyz="0.0" izz="0.015"/>
    </inertial>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0.290 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.4871" upper="2.4871" effort="40.0" velocity="8.90"/>
  </joint>

  <link name="link_3">
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0.020 0 0.295" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-4.7124" upper="4.7124" effort="20.0" velocity="12.22"/>
  </joint>

  <link name="link_4">
    <inertial>
      <mass value="0.7"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.3300" upper="2.3300" effort="20.0" velocity="10.47"/>
  </joint>

  <link name="link_5">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0.070 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-4.7124" upper="4.7124" effort="10.0" velocity="17.45"/>
  </joint>

  <link name="link_6">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link_6"/>
    <child link="tool0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="tool0">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
