<?xml version="1.0"?>
<!-- Simplified Kinova Gen3 Lite URDF - correct kinematics, no meshes -->
<!-- Joint axes: all Z-axis with frame rotations between links (6-DOF) -->
<!-- Real Gen3 Lite has actuator position limits on all joints -->
<robot name="kinova_gen3_lite">
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.008" ixy="0.0" ixz="0.0" iyy="0.008" iyz="0.0" izz="0.008"/>
    </inertial>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.128" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="25" velocity="1.57"/>
  </joint>

  <link name="shoulder_link">
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.008" ixy="0.0" ixz="0.0" iyy="0.008" iyz="0.0" izz="0.004"/>
    </inertial>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="shoulder_link"/>
    <child link="arm_link"/>
    <origin xyz="0.030 0 0.115" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.41" upper="2.41" effort="25" velocity="1.57"/>
  </joint>

  <link name="arm_link">
    <inertial>
      <mass value="0.9"/>
      <inertia ixx="0.006" ixy="0.0" ixz="0.0" iyy="0.006" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.030 0 0.280" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="25" velocity="1.57"/>
  </joint>

  <link name="forearm_link">
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.004" ixy="0.0" ixz="0.0" iyy="0.004" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0 0 0.140" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.66" upper="2.66" effort="25" velocity="1.57"/>
  </joint>

  <link name="wrist_link">
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="wrist_link"/>
    <child link="hand_link"/>
    <origin xyz="0 0 0.105" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="25" velocity="1.57"/>
  </joint>

  <link name="hand_link">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="joint_6" type="revolute">
    <parent link="hand_link"/>
    <child link="end_effector_link"/>
    <origin xyz="0 0 0.0615" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="25" velocity="1.57"/>
  </joint>

  <link name="end_effector_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="ee_fixed_joint" type="fixed">
    <parent link="end_effector_link"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.0535" rpy="0 0 0"/>
  </joint>

  <link name="tool0">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
