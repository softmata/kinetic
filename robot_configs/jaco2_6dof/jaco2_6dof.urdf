<?xml version="1.0" ?>
<!-- Kinova JACO2 6-DOF URDF - 6-DOF assistive robot arm, no meshes -->
<!-- Joint axes: Z, Y, Z, Z, Z, Z -->
<!-- DH: d=[0.2755, -0.0098, -0.2073, -0.0743, -0.0743, -0.1600], a=[0, 0.410, 0, 0, 0, 0] -->
<!-- All joints are continuous (no limits) -->
<robot name="jaco2_6dof">
  <link name="base_link">
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="joint_1" type="continuous">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.2755" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit velocity="0.63" effort="6.8"/>
  </joint>

  <link name="link_1">
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="joint_2" type="continuous">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 -0.0098" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit velocity="0.63" effort="6.8"/>

  </joint>

  <link name="link_2">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="joint_3" type="continuous">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0.410 0 -0.2073" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>

  </joint>

  <link name="link_3">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_4" type="continuous">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 -0.0743" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit velocity="0.84" effort="1.0"/>

  </joint>

  <link name="link_4">
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="joint_5" type="continuous">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 -0.0743" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>

  </joint>

  <link name="link_5">
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="joint_6" type="continuous">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 -0.1600" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit velocity="0.84" effort="1.0"/>

  </joint>

  <link name="link_6">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link_6"/>
    <child link="tool0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="tool0">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
