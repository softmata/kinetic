<?xml version="1.0" ?>
<!-- Open Manipulator-X URDF - ROBOTIS 4-DOF educational arm, no meshes -->
<!-- Joint axes: Z, Y, Y, Y -->
<!-- DH: d=[0.077, 0, 0, 0], a=[0, 0.130, 0.124, 0.126] -->
<robot name="open_manipulator_x">
  <link name="base_link">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.077" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="2.5" velocity="4.82"/>
  </joint>

  <link name="link1">
    <inertial>
      <mass value="0.10"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0420" upper="1.8675" effort="2.5" velocity="4.82"/>
  </joint>

  <link name="link2">
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.00008"/>
    </inertial>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0.130 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0996" upper="1.4835" effort="2.5" velocity="4.82"/>
  </joint>

  <link name="link3">
    <inertial>
      <mass value="0.06"/>
      <inertia ixx="0.00008" ixy="0.0" ixz="0.0" iyy="0.00008" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.124 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.7453" upper="2.0420" effort="2.5" velocity="4.82"/>
  </joint>

  <link name="link4">
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="0.00003" ixy="0.0" ixz="0.0" iyy="0.00003" iyz="0.0" izz="0.00003"/>
    </inertial>
  </link>

  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link4"/>
    <child link="end_effector_link"/>
    <origin xyz="0.126 0 0" rpy="0 0 0"/>
  </joint>

  <link name="end_effector_link">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
