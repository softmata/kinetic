<?xml version="1.0" ?>
<!-- UR30 URDF - correct kinematics matching ur_description, no meshes -->
<!-- Joint axes: Z, Y, Y, Y, Z, Y (standard UR convention) -->
<!-- DH: d=[0.2095, 0, 0, 0.17415, 0.11985, 0.11655], a=[0, -0.8620, -0.7287, 0, 0, 0] -->
<robot name="ur30">
  <link name="base_link">
    <inertial>
