<?xml version="1.0"?>
<!-- Simplified xArm5 URDF - correct kinematics, no meshes -->
<!-- Joint axes: Z, Y, Y, Z, Y (5-DOF) -->
<!-- DH: d=[0.267, 0, 0, 0.3425, 0], a=[0, 0.289, 0, 0, 0.076] -->
<robot name="xarm5">
  <link name="link_base">
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="link_base"/>
    <child link="link1"/>
    <origin xyz="0 0 0.267" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="50" velocity="3.14"/>
  </joint>

  <link name="link1">
    <inertial>
      <mass value="2.3"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0595" upper="2.0944" effort="50" velocity="3.14"/>
  </joint>

  <link name="link2">
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 -0.289 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.9270" upper="0.1920" effort="32" velocity="3.14"/>
  </joint>

  <link name="link3">
    <inertial>
      <mass value="1.2"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.3425" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="32" velocity="3.14"/>
  </joint>

  <link name="link4">
    <inertial>
      <mass value="1.1"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.6930" upper="1.6930" effort="32" velocity="3.14"/>
  </joint>

  <link name="link5">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="joint_eef" type="fixed">
    <parent link="link5"/>
    <child link="link_eef"/>
    <origin xyz="0 0 0.076" rpy="0 0 0"/>
  </joint>

  <link name="link_eef">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
