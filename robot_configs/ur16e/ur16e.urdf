<?xml version="1.0" ?>
<!-- UR16e URDF - correct kinematics matching ur_description, no meshes -->
<!-- Joint axes: Z, Y, Y, Y, Z, Y (standard UR convention) -->
<!-- DH: d=[0.1807, 0, 0, 0.17415, 0.11985, 0.11655], a=[0, -0.4784, -0.36, 0, 0, 0] -->
<robot name="ur16e">
  <link name="base_link">
