<?xml version="1.0" ?>
<!-- UR10e URDF - correct kinematics matching ur_description, no meshes -->
<!-- Joint axes: Z, Y, Y, Y, Z, Y (standard UR convention) -->
<!-- DH: d=[0.1807, 0, 0, 0.1149, 0.1157, 0.0922], a=[0, -0.6127, -0.5716, 0, 0, 0] -->
<robot name="ur10e">
  <link name="base_link">
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    <collision>
      <geometry><cylinder radius="0.090" length="0.1807"/></geometry>
      <origin xyz="0 0 0.090" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.1807" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="330.0" velocity="2.0944"/>
  </joint>

  <link name="shoulder_link">
