    <child link="upper_arm_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2832" upper="6.2832" effort="330.0" velocity="2.0944"/>
  </joint>

  <link name="upper_arm_link">
