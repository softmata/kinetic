<?xml version="1.0" ?>
<!-- Trossen ReactorX-150 URDF - 5-DOF arm, no meshes -->
<!-- Joint axes: Z, Y, Y, Y, Z -->
<!-- DH: d=[0.0893, 0, 0, 0, 0.065], a=[0, 0.1503, 0.150, 0.060, 0] -->
<robot name="trossen_rx150">
  <link name="base_link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="waist" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.0893" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10.0" velocity="6.2832"/>
  </joint>

  <link name="shoulder_link">
    <inertial>
      <mass value="0.35"/>
      <inertia ixx="0.0008" ixy="0.0" ixz="0.0" iyy="0.0008" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="shoulder" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8675" upper="1.8675" effort="10.0" velocity="6.2832"/>
  </joint>

  <link name="upper_arm_link">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0006" ixy="0.0" ixz="0.0" iyy="0.0006" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="elbow" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.1503 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.2689" upper="2.2689" effort="7.0" velocity="6.2832"/>
  </joint>

  <link name="forearm_link">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0004" ixy="0.0" ixz="0.0" iyy="0.0004" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="wrist_angle" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0.150 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.9722" upper="1.9722" effort="5.0" velocity="6.2832"/>
  </joint>

  <link name="wrist_link">
    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="wrist_rotate" type="revolute">
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <origin xyz="0.060 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="3.0" velocity="6.2832"/>
  </joint>

  <link name="gripper_link">
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0" iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="ee_fixed" type="fixed">
    <parent link="gripper_link"/>
    <child link="end_effector_link"/>
    <origin xyz="0.065 0 0" rpy="0 0 0"/>
  </joint>

  <link name="end_effector_link">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
