<?xml version="1.0" ?>
<!-- Fetch Mobile Manipulator URDF - 7-DOF arm on mobile base, no meshes -->
<!-- Joint axes: Z, Y, X, Y, X, Y, X -->
<!-- DH: a=[0.117, 0.299, 0, 0.325, 0, 0, 0], d=[0.4, 0, 0, 0, 0, 0, 0] -->
<robot name="fetch">
  <link name="base_link">
    <inertial>
      <mass value="70.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="0.5"/>
    </inertial>
  </link>

  <joint name="torso_lift_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="torso_lift_link"/>
    <origin xyz="-0.086875 0 0.37743" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.4" effort="450.0" velocity="0.1"/>
  </joint>

  <link name="torso_lift_link">
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.05"/>
    </inertial>
  </link>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="torso_lift_link"/>
    <child link="shoulder_pan_link"/>
    <origin xyz="0.117 0 0.4" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.6056" upper="1.6056" effort="33.82" velocity="1.256"/>
  </joint>

  <link name="shoulder_pan_link">
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_pan_link"/>
    <child link="shoulder_lift_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.2210" upper="1.5180" effort="131.76" velocity="1.454"/>
  </joint>

  <link name="shoulder_lift_link">
    <inertial>
      <mass value="4.0"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="upperarm_roll_joint" type="continuous">
    <parent link="shoulder_lift_link"/>
    <child link="upperarm_roll_link"/>
    <origin xyz="0.299 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="76.94" velocity="1.571"/>
  </joint>

  <link name="upperarm_roll_link">
    <inertial>
      <mass value="2.1"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="elbow_flex_joint" type="revolute">
    <parent link="upperarm_roll_link"/>
    <child link="elbow_flex_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.2510" upper="2.2510" effort="66.18" velocity="1.521"/>
  </joint>

  <link name="elbow_flex_link">
    <inertial>
      <mass value="2.3"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="forearm_roll_joint" type="continuous">
    <parent link="elbow_flex_link"/>
    <child link="forearm_roll_link"/>
    <origin xyz="0.325 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="29.35" velocity="1.571"/>
  </joint>

  <link name="forearm_roll_link">
    <inertial>
      <mass value="1.6"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="wrist_flex_joint" type="revolute">
    <parent link="forearm_roll_link"/>
    <child link="wrist_flex_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.1600" upper="2.1600" effort="25.7" velocity="2.268"/>
  </joint>

  <link name="wrist_flex_link">
    <inertial>
      <mass value="1.1"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="wrist_roll_joint" type="continuous">
    <parent link="wrist_flex_link"/>
    <child link="wrist_roll_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="7.36" velocity="2.268"/>
  </joint>

  <link name="wrist_roll_link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="gripper_fixed_joint" type="fixed">
    <parent link="wrist_roll_link"/>
    <child link="gripper_link"/>
    <origin xyz="0.166 0 0" rpy="0 0 0"/>
  </joint>

  <link name="gripper_link">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>
</robot>
