<?xml version="1.0" ?>
<!-- Koch v1.1 URDF - HuggingFace LeRobot 6-DOF arm, no meshes -->
<!-- Joint axes: Z, Y, Y, Y, Z, Y (standard 6-DOF convention) -->
<!-- DH: d=[0.065, 0, 0, 0.050, 0.050, 0.040], a=[0, 0.130, 0.124, 0, 0, 0] -->
<robot name="koch_v1">
  <link name="base_link">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0008" ixy="0.0" ixz="0.0" iyy="0.0008" iyz="0.0" izz="0.0008"/>
    </inertial>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.065" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.6180" upper="2.6180" effort="3.0" velocity="5.76"/>
  </joint>

  <link name="link1">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6180" upper="2.6180" effort="3.0" velocity="5.76"/>
  </joint>

  <link name="link2">
    <inertial>
      <mass value="0.18"/>
      <inertia ixx="0.0004" ixy="0.0" ixz="0.0" iyy="0.0004" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0.130 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6180" upper="2.6180" effort="3.0" velocity="5.76"/>
  </joint>

  <link name="link3">
    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.124 0 0.050" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6180" upper="2.6180" effort="3.0" velocity="5.76"/>
  </joint>

  <link name="link4">
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.00006"/>
    </inertial>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 -0.050 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.6180" upper="2.6180" effort="3.0" velocity="5.76"/>
  </joint>

  <link name="link5">
    <inertial>
      <mass value="0.06"/>
      <inertia ixx="0.00006" ixy="0.0" ixz="0.0" iyy="0.00006" iyz="0.0" izz="0.00006"/>
    </inertial>
  </link>

  <joint name="joint_6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0.040 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6180" upper="2.6180" effort="3.0" velocity="5.76"/>
  </joint>

  <link name="link6">
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="0.00003" ixy="0.0" ixz="0.0" iyy="0.00003" iyz="0.0" izz="0.00003"/>
    </inertial>
  </link>

  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link6"/>
    <child link="end_effector"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="end_effector">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
