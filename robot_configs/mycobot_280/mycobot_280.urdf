<?xml version="1.0"?>
<!-- Simplified Elephant Robotics myCobot 280 URDF - correct kinematics, no meshes -->
<!-- Educational 6-DOF robot -->
<!-- Joint axes: Z, Y, Y, Y, Z, Y -->
<!-- DH: d=[0.131, 0, 0, 0.065, 0.065, 0.045], a=[0, -0.110, -0.110, 0, 0, 0] -->
<robot name="mycobot_280">
  <link name="base_link">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.131" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8798" upper="2.8798" effort="5" velocity="3.14"/>
  </joint>

  <link name="link1">
    <inertial>
      <mass value="0.25"/>
      <inertia ixx="0.0008" ixy="0.0" ixz="0.0" iyy="0.0008" iyz="0.0" izz="0.0004"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.8798" upper="2.8798" effort="5" velocity="3.14"/>
  </joint>

  <link name="link2">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0006" ixy="0.0" ixz="0.0" iyy="0.0006" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="-0.110 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.8798" upper="2.8798" effort="5" velocity="3.14"/>
  </joint>

  <link name="link3">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0004" ixy="0.0" ixz="0.0" iyy="0.0004" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="-0.110 0 0.065" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.8798" upper="2.8798" effort="5" velocity="3.14"/>
  </joint>

  <link name="link4">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 -0.065 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8798" upper="2.8798" effort="5" velocity="3.14"/>
  </joint>

  <link name="link5">
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0.045 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.8798" upper="2.8798" effort="5" velocity="3.14"/>
  </joint>

  <link name="link6">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link6"/>
    <child link="tool0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="tool0">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
