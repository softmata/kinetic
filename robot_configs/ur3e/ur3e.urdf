<?xml version="1.0" ?>
<!-- UR3e URDF - correct kinematics matching ur_description, no meshes -->
<!-- Joint axes: Z, Y, Y, Y, Z, Y (standard UR convention) -->
<!-- DH: d=[0.15185, 0, 0, 0.13105, 0.08535, 0.0921], a=[0, -0.24355, -0.2132, 0, 0, 0] -->
<robot name="ur3e">
  <link name="base_link">
    <inertial>
