<?xml version="1.0" ?>
<!-- WidowX 250 URDF - Trossen Robotics 6-DOF arm, no meshes -->
<!-- Joint axes: Z, Y, Y, Y, Z, Y (standard 6-DOF convention) -->
<!-- DH: d=[0.0725, 0, 0, 0.065, 0.0385, 0.066], a=[0, 0.206, 0.200, 0, 0, 0] -->
<robot name="widowx_250">
  <link name="base_link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="waist" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.0725" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10.0" velocity="6.28"/>
  </joint>

  <link name="shoulder_link">
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="shoulder" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8850" upper="1.9897" effort="10.0" velocity="6.28"/>
  </joint>

  <link name="upper_arm_link">
    <inertial>
      <mass value="0.35"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="elbow" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.206 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8850" upper="1.6232" effort="10.0" velocity="6.28"/>
  </joint>

  <link name="forearm_link">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="forearm_roll" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0.200 0 0.065" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.7453" upper="1.7453" effort="10.0" velocity="6.28"/>
  </joint>

  <link name="wrist_link">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="wrist_angle" type="revolute">
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <origin xyz="0 -0.0385 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.5656" upper="2.5656" effort="10.0" velocity="6.28"/>
  </joint>

  <link name="gripper_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="wrist_rotate" type="revolute">
    <parent link="gripper_link"/>
    <child link="ee_link"/>
    <origin xyz="0 0.066 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="10.0" velocity="6.28"/>
  </joint>

  <link name="ee_link">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
