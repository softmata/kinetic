<?xml version="1.0" ?>
<!-- Techman TM5-700 URDF - 6-DOF collaborative robot, OPW-compatible, no meshes -->
<!-- Joint axes: Z, Y, Y, Z, Y, Z -->
<!-- DH: a=[0, 0.329, 0.3115, 0, 0, 0], d=[0.1452, 0, 0, 0.1223, 0.106, 0.1144] -->
<robot name="techman_tm5_700">
  <link name="base_link">
    <inertial>
      <mass value="6.0"/>
      <inertia ixx="0.04" ixy="0.0" ixz="0.0" iyy="0.04" iyz="0.0" izz="0.04"/>
    </inertial>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.1452" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-4.7124" upper="4.7124" effort="100.0" velocity="3.1416"/>
  </joint>

  <link name="link_1">
    <inertial>
      <mass value="4.5"/>
      <inertia ixx="0.03" ixy="0.0" ixz="0.0" iyy="0.03" iyz="0.0" izz="0.015"/>
    </inertial>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="100.0" velocity="3.1416"/>
  </joint>

  <link name="link_2">
    <inertial>
      <mass value="6.0"/>
      <inertia ixx="0.05" ixy="0.0" ixz="0.0" iyy="0.05" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0.329 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.7053" upper="2.7053" effort="50.0" velocity="3.1416"/>
  </joint>

  <link name="link_3">
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0.3115 0 0.1223" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="30.0" velocity="3.9270"/>
  </joint>

  <link name="link_4">
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 -0.106 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="30.0" velocity="3.9270"/>
  </joint>

  <link name="link_5">
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0.1144 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-4.7124" upper="4.7124" effort="15.0" velocity="5.5851"/>
  </joint>

  <link name="link_6">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link_6"/>
    <child link="tool0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="tool0">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
