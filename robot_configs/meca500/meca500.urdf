<?xml version="1.0"?>
<!-- Simplified Mecademic Meca500 URDF - correct kinematics, no meshes -->
<!-- Tiny industrial 6-DOF robot -->
<!-- Joint axes: Z, Y, Y, Y, Z, Y -->
<!-- DH: d=[0.135, 0, 0, 0.070, 0, 0.050], a=[0, 0.135, 0, 0, 0, 0] -->
<robot name="meca500">
  <link name="base_link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.135" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0543" upper="3.0543" effort="5" velocity="8.72"/>
  </joint>

  <link name="link1">
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.2217" upper="1.2217" effort="5" velocity="8.72"/>
  </joint>

  <link name="link2">
    <inertial>
      <mass value="0.7"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 -0.135 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="2.3562" effort="3" velocity="10.47"/>
  </joint>

  <link name="link3">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.070" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.9671" upper="2.9671" effort="1.5" velocity="13.96"/>
  </joint>

  <link name="link4">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0071" upper="2.0071" effort="1.5" velocity="13.96"/>
  </joint>

  <link name="link5">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2832" upper="6.2832" effort="0.7" velocity="20.94"/>
  </joint>

  <link name="link6">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link6"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.050" rpy="0 0 0"/>
  </joint>

  <link name="tool0">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
</robot>
